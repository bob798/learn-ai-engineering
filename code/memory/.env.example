# ============================================
# Memory Demo 环境变量配置
# 复制为 .env 后填入：cp .env.example .env
# ============================================

# 硅基流动 SiliconFlow（推荐国内用户，一个 key 同时给 embedding + chat）
# 注册：https://siliconflow.cn
SILICONFLOW_API_KEY=your_siliconflow_key_here

# 智谱 AI ZhipuAI  注册：https://open.bigmodel.cn
ZHIPU_API_KEY=your_zhipu_key_here

# 阿里云 DashScope（通义千问）  注册：https://dashscope.aliyun.com
DASHSCOPE_API_KEY=your_dashscope_key_here

# OpenAI
OPENAI_API_KEY=your_openai_key_here

# 当前使用的提供商: "siliconflow" | "zhipu" | "qwen" | "openai"
PROVIDER=siliconflow

# 可选：自定义模型名（不设则用各提供商默认）
# EMBED_MODEL=BAAI/bge-m3
# CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
